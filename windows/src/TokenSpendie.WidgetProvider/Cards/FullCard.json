{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "${ringDataUri}",
              "width": "64px",
              "height": "64px",
              "altText": "Session usage ring"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "verticalContentAlignment": "center",
          "items": [
            {
              "type": "TextBlock",
              "text": "Token Spendie",
              "weight": "Bolder"
            },
            {
              "type": "TextBlock",
              "text": "${sessionLine}",
              "wrap": true,
              "spacing": "None"
            },
            {
              "type": "TextBlock",
              "text": "${weeklyLine}",
              "wrap": true,
              "isSubtle": true,
              "spacing": "None"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${footerText}",
      "isSubtle": true,
      "size": "Small",
      "wrap": true,
      "spacing": "Medium"
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "Refresh",
      "verb": "refresh"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Open Token Spendie",
      "url": "tokenspendie://open"
    }
  ]
}
